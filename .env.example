TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Phase C: Telethon (читать канал с личного аккаунта). Это НЕ Bot API выше. ---
#
# TELEGRAM_API_ID и TELEGRAM_API_HASH — с https://my.telegram.org
#   1) Войти номером Telegram (SMS/приложение).
#   2) API development tools → Create new application (любое имя/short name).
#   3) Скопировать api_id (число) и api_hash (строка). Одна пара на аккаунт, можно на все свои скрипты.
#
# TELEGRAM_SESSION_PATH — необязательно. По умолчанию в скрипте: user_data/.secrets/telegram_signals.session
#   В Docker том ./user_data смонтирован в /freqtrade/user_data — кладите сессию туда, путь от корня проекта на хосте:
#   user_data/.secrets/telegram_signals.session
#   Внутри контейнера то же: /freqtrade/user_data/.secrets/telegram_signals.session
#
# TELEGRAM_2FA_PASSWORD — только если на аккаунте включён облачный пароль (Настройки → Конфиденциальность → Облачный пароль).
#   Лучше не писать в .env; при первом входе скрипт спросит в интерактиве. В .env — только если очень нужен безTTY-запуск.
#
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# TELEGRAM_SESSION_PATH=user_data/.secrets/telegram_signals.session
# TELEGRAM_2FA_PASSWORD=
#
# Docker: TELEGRAM_* пробрасываются в контейнер через docker-compose.yml.
#
# ENABLE_TELEGRAM_SIGNAL_AUTH=1 — при старте контейнера: проверка сессии; иначе QR в бот + отбивка после скана.
ENABLE_TELEGRAM_SIGNAL_AUTH=0

# Одноразовые команды в контейнере без preflight: docker compose run --rm --entrypoint python freqtrade fork/scripts/...

EXCHANGE_KEY=
EXCHANGE_SECRET=

TG_PROXY=
